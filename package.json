{
  "name": "radiflow-player",
  "productName": "RadiFlow Player",
  "private": true,
  "version": "0.1.0",
  "description": "RadiFlow Player is a desktop music player with dynamic backgrounds, synced lyrics, playlists, and local library support.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "backend:dev": "tsx server.ts",
    "electron:dev": "node scripts/electron-dev.mjs",
    "quick:start": "node scripts/quick-start.mjs",
    "build:renderer": "vite build",
    "build:server:wrapper": "esbuild server.ts --platform=node --target=node20 --format=esm --outfile=dist-electron/server.js",
    "build:server:native": "cargo build --manifest-path rust-backend/Cargo.toml --release && node scripts/copy-rust-backend.mjs",
    "build:server": "npm run build:server:wrapper && npm run build:server:native",
    "build": "npm run build:renderer && npm run build:server",
    "electron:preview": "node scripts/electron-preview.mjs",
    "dist:win": "npm run build && electron-builder --win dir",
    "preview": "vite preview --host 127.0.0.1 --port 5173",
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; ['dist','dist-electron','release','rust-backend/target','.electron-preview'].forEach((target) => fs.rmSync(target, { recursive: true, force: true }));\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "colorthief": "^3.3.1",
    "dotenv": "^17.2.3",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "music-metadata": "^11.12.3",
    "music-metadata-browser": "^2.5.11",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.3",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.radiflow.player",
    "productName": "RadiFlow Player",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "main.js",
      "logo.ico",
      "package.json"
    ],
    "win": {
      "icon": "logo.ico",
      "signAndEditExecutable": false
    }
  }
}
